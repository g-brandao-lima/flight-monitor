# Órbita — exemplo de secrets. Copiar para .env e preencher.
# NUNCA commitar .env.

# Banco ------------------------------------------------------------------
# SQLite (dev local):
DATABASE_URL=sqlite:///./flight_monitor.db
# PostgreSQL (produção via Neon.tech):
# DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.sa-east-1.aws.neon.tech/dbname?sslmode=require

# URL base pública da aplicação (OAuth callback, emails, canonical, OG image)
APP_BASE_URL=http://localhost:8000

# Sessão ----------------------------------------------------------------
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin panel /admin/stats. Só quem tem esse email vê o painel.
ADMIN_EMAIL=

# Fontes de preço ------------------------------------------------------
# Travelpayouts (primária). Cadastrar em travelpayouts.com, pegar token em
# Profile → API token. Marker (affiliate ID) vem junto.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=714304

# SerpAPI (fallback). serpapi.com free tier 250 req/mês.
SERPAPI_API_KEY=

# Email -----------------------------------------------------------------
# Gmail SMTP com senha de app (myaccount.google.com → Security → App passwords).
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENT=

# Observabilidade -------------------------------------------------------
# Sentry (opcional). Vazio desativa.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
